{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:read-dirs",
    "fs:write-all",
    {
      "identifier": "fs:scope",
      "allow": [
        "$APPCACHE/recordings",
        "$APPCACHE/recordings/**"
      ]
    }
  ]
}
